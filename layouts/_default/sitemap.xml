{{- $pages := where .Site.Pages "Kind" "page" -}}
{{- $pages = where $pages "Params.noindex" "!=" true -}}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{{- range $pages }}
  {{- $sec := .Section }}
  {{- $prio := "0.5" }}
  {{- $freq := "monthly" }}
  {{- if or (eq $sec "riski-i-posledstviya") (eq $sec "oslozhneniya") (eq $sec "kliniki") (eq $sec "sudebnye-dela") (eq $sec "novosti") }}
    {{- $prio = "1.0" }}
    {{- $freq = "weekly" }}
  {{- else if or (eq $sec "faq") (eq $sec "pobochnye-effekty") (eq $sec "oborudovanie") (eq $sec "otzyvy") (eq $sec "pravo") (eq $sec "zamena-hrustalika") (eq $sec "lazernaya-koagulyaciya") }}
    {{- $prio = "0.8" }}
  {{- else if or (eq $sec "chat") (eq $sec "mify-o-lkz") (eq $sec "issledovaniya") (eq $sec "kakoj-metod-lazernoj-korrekcii-luchshe") (eq $sec "alternativy-lkz") (eq $sec "chto-delat-esli") }}
    {{- $prio = "0.6" }}
  {{- else if or (eq $sec "geografiya") (eq $sec "tags") (eq $sec "categories") }}
    {{- $prio = "0.3" }}
  {{- end }}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{- if .Lastmod }}<lastmod>{{ .Lastmod.Format "2006-01-02T15:04:05-07:00" }}</lastmod>{{ else if .Date }}<lastmod>{{ .Date.Format "2006-01-02T15:04:05-07:00" }}</lastmod>{{ end }}
    <changefreq>{{ $freq }}</changefreq>
    <priority>{{ $prio }}</priority>
  </url>
{{- end }}
</urlset>
