rules_version = "2";
service cloud.firestore {
  match /databases/{database}/documents {

    match /boards/{board} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /threads/{thread} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /comments/{comment} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
